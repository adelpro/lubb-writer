{
  "manifest_version": 2,
  "name": "Lubb Writer",
  "version": "1.0.0",
  "description": "AI-powered text enhancement anywhere in your browser",
  "icons": {
    "16": "/icons/icon16.png",
    "48": "/icons/icon48.png",
    "128": "/icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "/popup/popup.html",
    "default_icon": {
      "16": "/icons/icon16.png",
      "48": "/icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["/background/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["/content/content.js"],
      "css": ["/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "commands": {
    "enhance-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Enhance selected text with Lubb Writer"
    }
  },
  "options_page": "/options/options.html",
  "host_permissions": [
    "<all_urls>"
  ]
}
