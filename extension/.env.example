# Lubb Writer Extension Environment Variables
# ============================================
# 
# This file is a template for environment configuration.
# Copy this file to the appropriate environment file:
#   - For development: .env.development (or .env)
#   - For production:  .env.production
#
# Environment files are automatically loaded by Plasmo:
#   - plasmo dev uses .env.development
#   - plasmo build uses .env.production
#
# You can also use .env for both (overrides .env.development and .env.production)

# API URL - The base URL for the Lubb Writer API
# Development (default):
PLASMO_API_URL=https://lubb-writer-api.adelpro.us.kg

# Production (update for your production API):
# PLASMO_API_URL=https://your-production-api.com
