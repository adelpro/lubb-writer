# =============================================================================
# Server Configuration
# =============================================================================
PORT=3001

# =============================================================================
# Authentication
# =============================================================================
# Bearer token for API authentication (optional, recommended for production)
API_TOKEN=your_api_token_here

# =============================================================================
# AI Providers Configuration
# =============================================================================
# At least one provider must be configured

# OpenAI Provider
OPENAI_API_KEY=sk-your_openai_key_here
# Optional: Override the base URL (defaults to https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: Specify which models to enable (defaults to gpt-4o, gpt-4o-mini)
OPENAI_MODELS=gpt-4o,gpt-4o-mini

# Anthropic Provider
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# Optional: Specify which models to enable (defaults to claude-3-5-sonnet)
ANTHROPIC_MODELS=claude-3-5-sonnet,claude-3-opus

# Google Provider
GOOGLE_API_KEY=your_google_api_key_here
# Optional: Specify which models to enable (defaults to gemini-1.5-flash)
GOOGLE_MODELS=gemini-1.5-flash,gemini-1.5-pro

# =============================================================================
# Custom OpenAI-Compatible Providers (Optional)
# =============================================================================
# Add up to 10 custom providers (MiniMax, Ollama, LM Studio, etc.)
# Each provider requires BASE_URL and at least one MODEL

# Example 1: MiniMax (OpenAI-compatible)
CUSTOM_PROVIDER_1_API_KEY=your_minimax_key_here
CUSTOM_PROVIDER_1_BASE_URL=https://api.minimax.io/v1
CUSTOM_PROVIDER_1_NAME=MiniMax
CUSTOM_PROVIDER_1_MODELS=MiniMax-M2.1,MiniMax-M2.1-lightning

# Example 2: Ollama (local)
# CUSTOM_PROVIDER_2_API_KEY=
# CUSTOM_PROVIDER_2_BASE_URL=http://localhost:11434/v1
# CUSTOM_PROVIDER_2_MODELS=llama2,mistral,qwen

# Example 3: LM Studio (local)
# CUSTOM_PROVIDER_3_API_KEY=sk-local
# CUSTOM_PROVIDER_3_BASE_URL=http://localhost:1234/v1
# CUSTOM_PROVIDER_3_MODELS=text-gen

# =============================================================================
# Default Settings
# =============================================================================
# Default model to use when not specified (must be from configured models above)
DEFAULT_MODEL=MiniMax-M2.1
